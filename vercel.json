{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "pnpm install",
  "rewrites": [
    { "source": "/api/member-login", "destination": "/api/member?route=login" },
    { "source": "/api/member-refresh", "destination": "/api/member?route=refresh" },
    { "source": "/api/member-claim", "destination": "/api/member?route=claim" },
    { "source": "/api/member-password", "destination": "/api/member?route=password" },
    { "source": "/api/member-register", "destination": "/api/member?route=register" },
    { "source": "/api/directory-names", "destination": "/api/member?route=directory-names" },
    { "source": "/checkin/:slug*", "destination": "/index.html" },
    { "source": "/berlin", "destination": "/index.html" },
    { "source": "/sf", "destination": "/index.html" },
    { "source": "/global", "destination": "/index.html" },
    { "source": "/profile", "destination": "/index.html" },
    { "source": "/connections", "destination": "/index.html" },
    { "source": "/calendar", "destination": "/index.html" },
    { "source": "/claim", "destination": "/index.html" },
    { "source": "/join", "destination": "/index.html" }
  ]
}
