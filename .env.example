# -----------------------------------------------------------------------------
# Foresight Map – environment template
# Copy to .env.local (or .env) and fill in real values. Never commit secrets.
# Scripts (sync:sheet, migrate:sheet) load .env.local automatically.
# -----------------------------------------------------------------------------

# ----- Frontend (Vite) – exposed to client with VITE_ prefix -----------------
# Optional: Supabase (see src/INTEGRATION.md). Leave unset to use local JSON API.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: Base path for deployment (e.g. GitHub Pages subpath). Default: /
# VITE_BASE_PATH=/

# ----- Server (Express) ------------------------------------------------------
# Port for the API server (default: 3001)
PORT=3001

# Node environment: development | production (affects error messages)
NODE_ENV=development

# ----- Optional integrations (e.g. Edge Functions, email) ---------------------
# See src/INTEGRATION.md for Resend and other backends.
# RESEND_API_KEY=re_xxxx

# ----- Google Sheet as database (see docs/SHEETS_SYNC.md) ----------------------
# Spreadsheet ID from the sheet URL: .../d/SPREADSHEET_ID/edit
SPREADSHEET_ID=1kE0ogroOgXFBEH8y1qREU940ux41RUiLNE_rowXXAnQ

# For sync (Sheet → JSON): API key. Sheet must be "Anyone with the link can view".
# GOOGLE_SHEETS_API_KEY=your-google-api-key

# For one-time migration (JSON → Sheet): service account credentials.
# Share the sheet with the service account email as Editor.
# Option A: path to key file
# GOOGLE_APPLICATION_CREDENTIALS=./path-to-service-account-key.json
# Option B: JSON string (useful in CI/cloud)
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...",...}
