# -----------------------------------------------------------------------------
# Foresight Map – environment template
# Copy to .env.local (or .env) and fill in real values. Never commit secrets.
# Scripts (sync:sheet, sync:events, migrate:sheet, server) load .env.local automatically.
# -----------------------------------------------------------------------------

# ----- Frontend (Vite) – exposed to client with VITE_ prefix -----------------
# Optional: Base path for deployment (e.g. GitHub Pages subpath). Default: /
# VITE_BASE_PATH=/

# Optional: Supabase (see src/INTEGRATION.md). Leave unset to use local JSON API.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# ----- Server (Express) ------------------------------------------------------
# Port for the API server (default: 3001)
PORT=3001

# Node environment: development | production (affects error messages)
NODE_ENV=development

# ----- Google Sheet as database (see docs/SHEETS_SYNC.md) --------------------
# Spreadsheet ID from the sheet URL: .../d/SPREADSHEET_ID/edit
SPREADSHEET_ID=1kE0ogroOgXFBEH8y1qREU940ux41RUiLNE_rowXXAnQ

# Sync (Sheet → JSON) and read: API key. Sheet must be "Anyone with the link can view".
# Used by: GET /api/database, pnpm sync:sheet, api/checkins, api/rsvps, directory auth.
# GOOGLE_SHEETS_API_KEY=your-google-api-key
# (Some scripts also accept GOOGLE_API_KEY as an alias.)

# Write to sheet: service account. Share the sheet with the service account email as Editor.
# Used by: profile save, member-register, pnpm migrate:sheet, api/rsvps, etc.
# Option A: path to key file
# GOOGLE_APPLICATION_CREDENTIALS=./path-to-service-account-key.json
# Option B: JSON string (useful in CI/cloud and for serverless)
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...",...}

# ----- Luma API (see docs/LUMA_INTEGRATION.md) ---------------------------------
# Used by: pnpm sync:events. Requires Luma Plus subscription.
# API key: Luma calendar → Settings → Developer
# LUMA_API_KEY=your-luma-api-key
# Calendar API ID: from Luma calendar settings or URL
# LUMA_CALENDAR_API_ID=cal-xxxxxxxxxxxx

# ----- Signal Bot (check-in via Signal group) ---------------------------------
# URL of the signal-cli-rest-api container (Docker self-host).
# SIGNAL_API_URL=http://localhost:8080

# Phone number registered with signal-cli (E.164 format, e.g. +491701234567).
# SIGNAL_NUMBER=+491701234567

# Base64-encoded Signal group ID. Messages outside this group are ignored.
# SIGNAL_GROUP_ID=base64groupid==

# Node slug that this Signal group maps to ("berlin" or "sf").
# SIGNAL_NODE_SLUG=berlin

# Polling interval in milliseconds (default: 5000).
# SIGNAL_POLL_INTERVAL_MS=5000

# ----- Optional integrations (e.g. Edge Functions, email) ---------------------
# See src/INTEGRATION.md for Resend and other backends.
# RESEND_API_KEY=re_xxxx
